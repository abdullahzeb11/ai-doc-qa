# --- Supabase ---
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name (create this in the Supabase dashboard)
SUPABASE_STORAGE_BUCKET=documents

# --- Anthropic ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default chat model. Swap to claude-sonnet-4-6 for higher quality answers.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Voyage AI (embeddings) ---
# https://www.voyageai.com/ -> API keys
VOYAGE_API_KEY=
# voyage-3 is multilingual (Arabic + English), 1024 dimensions
VOYAGE_EMBEDDING_MODEL=voyage-3
